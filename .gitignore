# macOS
.DS_Store
.AppleDouble
.LSOverride

# Telemetry data (don't commit personal usage data)
# Ignore entire meta directory except .gitkeep
plugins/psd-coding-system/meta/*
!plugins/psd-coding-system/meta/.gitkeep

# Learning files (local working data, not shared via git)
plugins/psd-coding-system/docs/learnings/**/*.md
!plugins/psd-coding-system/docs/learnings/*/.gitkeep

# Evolve state (local per-machine, not shared)
plugins/psd-coding-system/docs/learnings/.evolve-state.json

# Python
__pycache__/
*.pyc

# Node modules if added later
node_modules/

# Logs
*.log

# FreshService credentials (never commit - CRITICAL SECURITY)
*.freshservice.env
plugins/psd-coding-system/.freshservice.env
.freshservice.env
.claude/setup-marker.log
